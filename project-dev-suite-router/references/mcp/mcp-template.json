{
  "mcpServers": {
    "mysql-custom": {
      "command": "node",
      "args": [
        "c:\\Users\\CYSWR\\.kiro\\mcp-servers\\mysql-custom\\index.js"
      ],
      "env": {
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "YOUR_PASSWORD",
        "MYSQL_DATABASE": "YOUR_DATABASE"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated",
        "--executablePath",
        "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
      ]
    },
    "drawio": {
      "command": "npx",
      "args": [
        "-y",
        "@next-ai-drawio/mcp-server@latest"
      ]
    }
  }
}